<div class="w-full max-w-2xl mx-auto bg-card p-6 rounded-xl border shadow-sm">
    <div class="mb-6 border-b pb-4 dark:border-zinc-800">
        <h1 class="text-2xl font-bold">Edit Peminjaman Ruangan</h1>
        <p class="text-muted-foreground text-sm">Ubah rincian peminjaman ruangan di bawah ini.</p>
    </div>

    <div id="notif" style="display:none;" class="p-3 mb-4 rounded-md text-sm font-medium"></div>

    <form id="editBookingForm" class="space-y-4">
        <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Pilih Ruangan</label>
            <select name="room_id" required class="form-select text-sm h-9 rounded-md border bg-transparent px-3">
                <% if (rooms && rooms.length > 0) { rooms.forEach(function(room) { %>
                    <option value="<%= room.id %>" <%= booking.room_id === room.id ? 'selected' : '' %>><%= room.name %></option>
                <% }); } %>
            </select>
        </div>

        <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Tanggal Peminjaman</label>
            <input type="date" name="tanggal" value="<%= formattedDate %>" required class="form-control text-sm h-9 rounded-md border bg-transparent px-3">
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
                <label class="text-sm font-medium">Jam Mulai</label>
                <input type="time" name="jam_mulai" value="<%= formattedStart %>" required class="form-control text-sm h-9 rounded-md border bg-transparent px-3">
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-sm font-medium">Jam Selesai</label>
                <input type="time" name="jam_selesai" value="<%= formattedEnd %>" required class="form-control text-sm h-9 rounded-md border bg-transparent px-3">
            </div>
        </div>

        <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Keperluan / Acara</label>
            <textarea name="purpose" rows="3" required class="form-control text-sm rounded-md border bg-transparent px-3 py-2" placeholder="Contoh: Rapat Koordinasi Panitia UART"><%= booking.purpose %></textarea>
        </div>

        <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Status Peminjaman</label>
            <select name="status" required class="form-select text-sm h-9 rounded-md border bg-transparent px-3">
                <option value="requested" <%= booking.status === 'requested' ? 'selected' : '' %>>MENUNGGU</option>
                <option value="approved" <%= booking.status === 'approved' ? 'selected' : '' %>>DISETUJUI (ACC)</option>
                <option value="completed" <%= booking.status === 'completed' ? 'selected' : '' %>>SELESAI</option>
                <option value="rejected" <%= booking.status === 'rejected' ? 'selected' : '' %>>DITOLAK</option>
            </select>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" id="submitBtn" class="bg-primary text-primary-foreground h-9 px-4 rounded-md text-sm font-medium hover:bg-primary/90">
                Simpan Perubahan
            </button>
            <a href="/bookings" class="border bg-background hover:bg-accent h-9 px-4 flex items-center rounded-md text-sm font-medium text-decoration-none text-dark">Batal</a>
        </div>
    </form>
</div>

<script>
    document.getElementById('editBookingForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const notif = document.getElementById('notif');
        const submitBtn = document.getElementById('submitBtn');

        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());

        submitBtn.disabled = true;
        submitBtn.innerText = "Menyimpan...";

        try {
            const response = await fetch('/bookings/<%= booking.id %>/edit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();
            notif.style.display = 'block';

            if (response.status === 200) {
                notif.className = "p-3 rounded-md text-sm font-medium bg-green-100 text-green-800 dark:bg-green-950/30 dark:text-green-400";
                notif.innerText = result.message;
                setTimeout(() => window.location.href = '/bookings', 1500);
            } else {
                notif.className = "p-3 rounded-md text-sm font-medium bg-red-100 text-red-800 dark:bg-red-950/30 dark:text-red-400";
                notif.innerText = result.error;
                submitBtn.disabled = false;
                submitBtn.innerText = "Simpan Perubahan";
            }
        } catch (err) {
            notif.style.display = 'block';
            notif.className = "p-3 rounded-md text-sm font-medium bg-red-100 text-red-800 dark:bg-red-950/30 dark:text-red-400";
            notif.innerText = "Terjadi kesalahan koneksi jaringan.";
            submitBtn.disabled = false;
            submitBtn.innerText = "Simpan Perubahan";
        }
    });
</script>
