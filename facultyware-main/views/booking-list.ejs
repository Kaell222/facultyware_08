<div class="flex flex-col gap-6">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold"><%= title %></h1>
            <p class="text-muted-foreground text-sm mt-1">
                <%= user.role === 'penanggung_jawab' ? 'Kelola dan verifikasi seluruh pengajuan peminjaman ruangan.' : 'Pantau status pengajuan peminjaman ruangan Anda.' %>
            </p>
        </div>
        <% if (user.role !== 'penanggung_jawab') { %>
            <a href="/bookings/add" class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4 py-2">
                + Ajukan Ruangan
            </a>
        <% } %>
    </div>

    <!-- Search Form -->
    <div class="flex items-center justify-between gap-4">
        <form action="/bookings" method="GET" class="flex items-center gap-2 w-full max-w-sm">
            <input type="text" name="search" placeholder="Cari nama peminjam, ruangan, atau keperluan..." value="<%= typeof search !== 'undefined' ? search : '' %>" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring dark:border-zinc-800" />
            <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-secondary text-secondary-foreground hover:bg-secondary/80 border dark:border-zinc-800 h-9 px-4">
                Cari
            </button>
            <% if (typeof search !== 'undefined' && search) { %>
                <a href="/bookings" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3 dark:border-zinc-800">
                    Batal
                </a>
            <% } %>
        </form>
    </div>

    <div class="rounded-xl border bg-card text-card-foreground shadow-sm overflow-hidden dark:border-zinc-800">
        <div class="relative w-full overflow-auto">
            <table class="w-full text-sm">
                <thead class="bg-muted/50 border-b">
                    <tr>
                        <th class="h-10 px-4 text-left font-bold">No.</th>
                        <th class="h-10 px-4 text-left font-bold">Peminjam</th>
                        <th class="h-10 px-4 text-left font-bold">Ruangan</th>
                        <th class="h-10 px-4 text-left font-bold">Jadwal (WIB)</th>
                        <th class="h-10 px-4 text-left font-bold">Keperluan</th>
                        <th class="h-10 px-4 text-left font-bold">Status</th>
                        <th class="h-10 px-4 text-center font-bold">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (bookings && bookings.length > 0) { %>
                        <% bookings.forEach(function(booking, index) { %>
                            <tr class="border-b hover:bg-muted/50 dark:border-zinc-800">
                                <td class="p-4"><%= (currentPage - 1) * limit + index + 1 %></td>
                                <td class="p-4 font-medium"><%= booking.borrower_name %></td>
                                <td class="p-4"><%= booking.room_name %></td>
                                <td class="p-4 text-muted-foreground">
                                    <%= new Date(booking.start_time).toLocaleString('id-ID', {dateStyle: 'short', timeStyle: 'short'}) %> <br> s.d <br>
                                    <%= new Date(booking.end_time).toLocaleString('id-ID', {dateStyle: 'short', timeStyle: 'short'}) %>
                                </td>
                                <td class="p-4"><%= booking.purpose %></td>
                                <td class="p-4">
                                    <% if (booking.status === 'approved') { %>
                                        <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">DISETUJUI</span>
                                    <% } else if (booking.status === 'rejected') { %>
                                        <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700">DITOLAK</span>
                                    <% } else if (booking.status === 'completed') { %>
                                        <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-700">SELESAI</span>
                                    <% } else { %>
                                        <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-orange-100 text-orange-700">MENUNGGU</span>
                                    <% } %>
                                </td>
                                <td class="p-4 text-center">
                                    <div class="flex gap-2 justify-center items-center">
                                        <% if (user.role === 'penanggung_jawab') { %>
                                            <!-- Quick Status Actions -->
                                            <% if (booking.status === 'requested') { %>
                                                <form action="/bookings/<%= booking.id %>/action" method="POST" class="inline">
                                                    <input type="hidden" name="action_status" value="approved">
                                                    <button type="submit" class="btn btn-sm btn-success text-xs px-2 py-1">ACC</button>
                                                </form>
                                                <form action="/bookings/<%= booking.id %>/action" method="POST" class="inline">
                                                    <input type="hidden" name="action_status" value="rejected">
                                                    <button type="submit" class="btn btn-sm btn-danger text-xs px-2 py-1">Tolak</button>
                                                </form>
                                            <% } else if (booking.status === 'approved') { %>
                                                <form action="/bookings/<%= booking.id %>/action" method="POST" class="inline">
                                                    <input type="hidden" name="action_status" value="completed">
                                                    <button type="submit" class="btn btn-sm btn-primary text-xs px-2 py-1">Selesai</button>
                                                </form>
                                            <% } %>

                                            <!-- Core Management Actions (Edit & Hapus) -->
                                            <a href="/bookings/<%= booking.id %>/edit" class="btn btn-sm btn-outline text-xs px-2 py-1 rounded border bg-transparent hover:bg-accent text-foreground">
                                                Edit
                                            </a>
                                            <form action="/bookings/<%= booking.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Apakah Anda yakin ingin menghapus peminjaman ini?');">
                                                <button type="submit" class="btn btn-sm btn-danger text-xs px-2 py-1 rounded">Hapus</button>
                                            </form>
                                        <% } %>

                                        <% if (user.role !== 'penanggung_jawab') { %>
                                            <% if (booking.status === 'requested') { %>
                                                <form action="/bookings/<%= booking.id %>/cancel" method="POST" class="inline">
                                                    <button type="submit" class="text-xs text-red-600 hover:underline">Batalkan</button>
                                                </form>
                                            <% } else if (booking.status === 'approved' || booking.status === 'completed') { %>
                                                <a href="/bookings/<%= booking.id %>/download" target="_blank" class="text-xs text-blue-600 hover:underline font-medium">Unduh PDF</a>
                                            <% } else { %>
                                                <span class="text-xs text-muted-foreground">-</span>
                                            <% } %>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="p-8 text-center text-muted-foreground">Belum ada data peminjaman ruangan.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination Controls -->
    <% if (totalPages > 1) { %>
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mt-2 text-xs text-muted-foreground">
            <span>
                Menampilkan halaman <strong><%= currentPage %></strong> dari <strong><%= totalPages %></strong> (Total <strong><%= totalRows %></strong> data)
            </span>
            <div class="flex items-center gap-1">
                <% if (currentPage > 1) { %>
                    <a href="/bookings?page=<%= currentPage - 1 %><%= typeof search !== 'undefined' && search ? '&search=' + encodeURIComponent(search) : '' %>" class="inline-flex items-center justify-center rounded-md border border-input bg-background hover:bg-accent h-8 px-3 dark:border-zinc-800">
                        Sebelumnya
                    </a>
                <% } %>
                
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="/bookings?page=<%= i %><%= typeof search !== 'undefined' && search ? '&search=' + encodeURIComponent(search) : '' %>" class="inline-flex items-center justify-center rounded-md <%= currentPage === i ? 'bg-primary text-primary-foreground font-bold' : 'border border-input bg-background hover:bg-accent dark:border-zinc-800' %> h-8 w-8">
                        <%= i %>
                    </a>
                <% } %>
                
                <% if (currentPage < totalPages) { %>
                    <a href="/bookings?page=<%= currentPage + 1 %><%= typeof search !== 'undefined' && search ? '&search=' + encodeURIComponent(search) : '' %>" class="inline-flex items-center justify-center rounded-md border border-input bg-background hover:bg-accent h-8 px-3 dark:border-zinc-800">
                        Selanjutnya
                    </a>
                <% } %>
            </div>
        </div>
    <% } %>
</div>